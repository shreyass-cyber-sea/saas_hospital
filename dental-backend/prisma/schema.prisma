generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Core Models ===

model Tenant {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  address         Json?            // { street, city, state, zip }
  phone           String?
  email           String?
  logo            String?
  subscription    TenantSubscription?
  isActive        Boolean          @default(true)
  settings        Json?            // { workingHours, slotDuration, etc }
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  users           User[]
  patients        Patient[]
  appointments    Appointment[]
  invoices        Invoice[]
  procedures      Procedure[]
  clinicalNotes   ClinicalNote[]
  doctorLeaves    DoctorLeave[]
  advancePayments AdvancePayment[]
  documents       PatientDocument[]
  inventoryItems  InventoryItem[]
  stockTransactions StockTransaction[]
  labCases        LabCase[]
  whatsappSessions WhatsAppSession[]
  whatsappPhoneMappings WhatsAppPhoneMapping[]
}

enum TenantSubscription {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

model User {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  name             String
  email            String   @unique
  password         String?
  role             Role     @default(RECEPTIONIST)
  phone            String?
  avatar           String?
  isActive         Boolean  @default(true)
  doctorProfile    Json?    // { specializations: [], experience: 0, etc }
  lastLogin        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointmentsAsDoctor   Appointment[] @relation("DoctorAppointments")
  appointmentsAsCreator  Appointment[] @relation("CreatorAppointments")
  invoicesAsDoctor       Invoice[]     @relation("DoctorInvoices")
  invoicesAsCreator      Invoice[]     @relation("CreatorInvoices")
  clinicalNotes          ClinicalNote[]
  doctorLeaves           DoctorLeave[]
  paymentRecords         InvoicePayment[]
  stockTransactions      StockTransaction[]
  labCases               LabCase[]
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  STAFF
}

// === Patient Management ===

model Patient {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  patientId        String    @unique // Human readable ID (e.g. PAT-001)
  name             String
  email            String?
  phone            String
  gender           Gender?
  dateOfBirth      DateTime?
  address          String?
  bloodGroup       String?
  photoUrl         String?
  medicalHistory   String[]
  emergencyContact Json?     // { name, relation, phone }
  totalVisits      Int       @default(0)
  lastVisit        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointments     Appointment[]
  clinicalNotes    ClinicalNote[]
  documents        PatientDocument[]
  invoices         Invoice[]
  advancePayments  AdvancePayment[]
  labCases         LabCase[]

  @@index([tenantId, createdAt])
  @@index([tenantId, phone])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model PatientDocument {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  name        String
  category    String   @default("report") // report, prescription, xray, scan, other
  fileUrl     String
  fileType    String?
  fileSize    Int?
  notes       String?
  uploadedAt  DateTime @default(now())
}

model ClinicalNote {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  patientId        String
  patient          Patient  @relation(fields: [patientId], references: [id])
  doctorId         String
  doctor           User     @relation(fields: [doctorId], references: [id])
  appointmentId    String?
  chiefComplaint   String?
  findings         String?
  diagnosis        String?
  treatmentPlan    String?
  prescriptions    Json[]   // [{ medicine, dosage, frequency, duration }]
  vitals           Json?    // { bp, weight, pulse, etc }
  clinicalFindings Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// === Appointments ===

model Appointment {
  id              String            @id @default(uuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  date            DateTime
  startTime       String            // HH:mm
  endTime         String?           // HH:mm
  status          AppointmentStatus @default(SCHEDULED)
  type            String?           // Consultation, Follow-up, Routine Check, Procedure
  chiefComplaint  String?
  tokenNumber     Int?
  cancelledReason String?
  createdByUserId String
  createdByUser   User              @relation("CreatorAppointments", fields: [createdByUserId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  invoices        Invoice[]

  @@index([tenantId, date])
  @@index([tenantId, doctorId, date])
  @@index([tenantId, status])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  IN_PROGRESS
}

model DoctorLeave {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  doctorId  String
  doctor    User     @relation(fields: [doctorId], references: [id])
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
}

// === Billing ===

model Procedure {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String
  code            String?
  category        String?
  defaultPrice    Float    @default(0)
  defaultDuration Int      @default(30)
  taxable         Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  invoiceItems    InvoiceItem[]
}

model Invoice {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          User          @relation("DoctorInvoices", fields: [doctorId], references: [id])
  appointmentId   String?
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])
  invoiceNumber   String        @unique
  status          InvoiceStatus @default(DRAFT)
  subtotal        Float         @default(0)
  totalDiscount   Float         @default(0)
  totalTax        Float         @default(0)
  grandTotal      Float         @default(0)
  paidAmount      Float         @default(0)
  pendingAmount   Float         @default(0)
  advanceUsed     Float         @default(0)
  notes           String?
  pdfUrl          String?
  createdByUserId String
  createdByUser   User          @relation("CreatorInvoices", fields: [createdByUserId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lineItems       InvoiceItem[]
  payments        InvoicePayment[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

model InvoiceItem {
  id              String     @id @default(uuid())
  invoiceId       String
  invoice         Invoice    @relation(fields: [invoiceId], references: [id])
  procedureId     String?
  procedure       Procedure? @relation(fields: [procedureId], references: [id])
  description     String
  quantity        Int        @default(1)
  unitPrice       Float      @default(0)
  discount        Float      @default(0)
  discountPercent Float      @default(0)
  taxPercent      Float      @default(18)
  taxAmount       Float      @default(0)
  totalAmount     Float      @default(0)
}

model InvoicePayment {
  id               String      @id @default(uuid())
  invoiceId        String
  invoice          Invoice     @relation(fields: [invoiceId], references: [id])
  amount           Float
  mode             PaymentMode @default(CASH)
  reference        String?
  paidAt           DateTime    @default(now())
  recordedByUserId String
  recordedByUser   User        @relation(fields: [recordedByUserId], references: [id])
}

enum PaymentMode {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  OTHER
}

model AdvancePayment {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id])
  amount        Float
  balanceAmount Float
  usedAmount    Float       @default(0)
  mode          PaymentMode @default(CASH)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// === Inventory Management ===

model InventoryItem {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  sku           String?
  category      String?  // consumable, instrument, implant, material, other
  description   String?
  unit          String   @default("piece") // piece, box, ml, gm, tube, pack
  currentStock  Float    @default(0)
  minimumStock  Float    @default(0)
  unitCost      Float    @default(0)
  sellingPrice  Float    @default(0)
  supplier      String?
  supplierPhone String?
  location      String?  // shelf/cabinet location
  expiryDate    DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  StockTransaction[]

  @@index([tenantId, isActive])
  @@index([tenantId, category])
}

enum TransactionType {
  PURCHASE
  USAGE
  RETURN
  ADJUSTMENT
  DISPOSAL
}

model StockTransaction {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  itemId        String
  item          InventoryItem  @relation(fields: [itemId], references: [id])
  type          TransactionType
  quantity      Float          // positive for IN, negative for OUT
  unitCost      Float          @default(0)
  totalCost     Float          @default(0)
  referenceNote String?
  patientId     String?
  performedById String
  performedBy   User           @relation(fields: [performedById], references: [id])
  createdAt     DateTime       @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, itemId])
}

model LabCase {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  patientId     String?
  patient       Patient? @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User     @relation(fields: [doctorId], references: [id])
  caseType      String   // crown, bridge, denture, aligner, other
  description   String?
  shade         String?
  labName       String?
  sentDate      DateTime @default(now())
  expectedDate  DateTime?
  deliveredDate DateTime?
  status        String   @default("SENT") // SENT, IN_PROGRESS, RECEIVED, REMADE
  cost          Float    @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// === WhatsApp Module (PostgreSQL) ===

enum WhatsAppSessionState {
  IDLE
  SELECTING_DOCTOR
  SELECTING_DATE
  SELECTING_SLOT
  ENTERING_PATIENT_NAME
  ENTERING_PATIENT_PHONE
  AWAITING_NAME
  AWAITING_DATE
  AWAITING_DOCTOR_CHOICE
  AWAITING_SLOT
  BOOKING_CONFIRM
  RESCHEDULE_SELECT
  CANCEL_SELECT
}

model WhatsAppSession {
  id              String               @id @default(uuid())
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  phone           String               // WhatsApp phone number
  state           WhatsAppSessionState @default(IDLE)
  context         Json?                // Stores flow context (doctorId, date, slot, etc.)
  lastInteraction DateTime             @default(now())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([phone, tenantId])
}

model WhatsAppPhoneMapping {
  id                    String   @id @default(uuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  whatsappPhoneNumberId String   @unique // WhatsApp Business API phone number ID
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
